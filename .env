PORT=8080

# Telebirr Credentials (get from developer.ethiotelecom.et)
TELEBIRR_APP_ID=your_app_id
TELEBIRR_APP_KEY=your_app_key
TELEBIRR_SHORT_CODE=your_short_code
TELEBIRR_PUBLIC_KEY=your_public_key

# Your public HTTPS callback URL (for webhooks)
CALLBACK_URL=https://your-domain.com/api/deposit/notify
